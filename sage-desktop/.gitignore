# Node / Vite
node_modules/
dist/
.vite/

# Rust / Cargo
src-tauri/target/
src-tauri/gen/

# Python sidecar caches
sidecar/__pycache__/
sidecar/**/__pycache__/
sidecar/.pytest_cache/
sidecar/**/*.pyc

# IDE / OS
.DS_Store
Thumbs.db
.idea/
.vscode/

# Updater signing — private keys MUST NEVER be committed.
# Only *.pub files are allowed through. Note `keys/*.key` matches the
# private key (sage-desktop.key) but NOT the pubkey (sage-desktop.key.pub)
# because gitignore globs don't span dots.
keys/*.key
src-tauri/keys/*.key

# PyInstaller + offline pip cache
offline/wheels/
sidecar/build/
sidecar/dist/
src-tauri/bin/sage-sidecar*

# Mutation + coverage reports
reports/
.stryker-tmp/

# Playwright artifacts — snapshots are committed, runtime output is not.
playwright-report/
test-results/
playwright/.cache/
