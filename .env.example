# ==============================================================
# Sage Framework — Environment Variables Template
# ==============================================================
# Copy this file to .env and fill in your actual credentials.
# NEVER commit the .env file to version control.
#
# Usage:
#   cp .env.example .env     (or copy .env.example .env on Windows)
#   python src/main.py api --project starter
#   make run PROJECT=meditation_app
# ==============================================================

# --------------------------------------------------------------
# Framework Settings
# --------------------------------------------------------------
# Active project (starter | meditation_app | four_in_a_line | medtech_team | <your project>)
SAGE_PROJECT=starter

# Path to your private solutions repository (optional).
# When set, SAGE reads and writes solution YAMLs and org.yaml from this directory
# instead of the bundled solutions/ directory. Mount this path into Docker to
# persist org.yaml and .sage/ audit databases across container restarts.
# Linux/WSL:  SAGE_SOLUTIONS_DIR=/home/user/my-solutions
# Windows:    SAGE_SOLUTIONS_DIR=C:/Users/you/my-solutions
# SAGE_SOLUTIONS_DIR=

# Minimal mode — set to 1 to skip ChromaDB/sentence-transformers
# Reduces RAM from ~600 MB to ~50 MB. Uses keyword search fallback.
# Recommended for: laptops, CI, demo environments.
SAGE_MINIMAL=0

# --------------------------------------------------------------
# Microsoft Teams Integration
# --------------------------------------------------------------
# Azure AD tenant ID (found in Azure Portal > Azure Active Directory > Overview)
TEAMS_TENANT_ID=your-azure-tenant-id-here

# App registration client ID (Azure Portal > App registrations > your app > Application ID)
TEAMS_CLIENT_ID=your-app-client-id-here

# App registration client secret (Azure Portal > App registrations > your app > Certificates & secrets)
TEAMS_CLIENT_SECRET=your-client-secret-here

# The Teams team ID (Graph API: GET /teams or from Teams URL)
TEAMS_TEAM_ID=your-teams-team-id-here

# The channel ID to monitor (Graph API: GET /teams/{team_id}/channels)
TEAMS_CHANNEL_ID=your-channel-id-here

# Incoming webhook URL for posting notifications
# (Teams channel > ... > Connectors > Incoming Webhook > Create)
TEAMS_INCOMING_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/...

# --------------------------------------------------------------
# GitLab Integration
# --------------------------------------------------------------
# Your GitLab instance URL (self-hosted or gitlab.com)
GITLAB_URL=https://gitlab.your-company.com

# Personal Access Token with api scope (GitLab > Profile > Access Tokens)
GITLAB_TOKEN=glpat-your-token-here

# Default project numeric ID (GitLab project > Settings > General)
GITLAB_PROJECT_ID=42

# --------------------------------------------------------------
# Metabase Integration
# --------------------------------------------------------------
# Metabase server URL
METABASE_URL=http://metabase.your-company.com

# Metabase service account username (email)
METABASE_USERNAME=sage-agent@your-company.com

# Metabase service account password
METABASE_PASSWORD=your-metabase-password-here

# The Metabase question (card) ID that queries for manufacturing errors
# (Metabase > Open question > check the URL: /question/123)
METABASE_ERROR_QUESTION_ID=123

# --------------------------------------------------------------
# SpiraTeam/SpiraTest Integration
# --------------------------------------------------------------
# Spira server URL (no trailing slash)
SPIRA_URL=https://spira.your-company.com

# Spira username
SPIRA_USERNAME=your.username

# Spira API key (Spira > Profile > API Key)
SPIRA_API_KEY=your-spira-api-key-here

# Default Spira project ID
SPIRA_PROJECT_ID=1

# --------------------------------------------------------------
# Serial Port Configuration
# --------------------------------------------------------------
# COM port for embedded device communication (Windows: COM3, Linux: /dev/ttyUSB0)
SERIAL_PORT=COM3

# (Baud rate is set in config.yaml, default 115200)

# --------------------------------------------------------------
# J-Link Debugger Configuration
# --------------------------------------------------------------
# Target MCU device name (e.g. STM32F407VG, nRF52840_xxAA, LPC1768)
JLINK_DEVICE=STM32F407VG

# J-Link serial number (optional, leave empty to use first detected)
JLINK_SERIAL=

# (Interface and speed are set in config.yaml: SWD @ 4000 kHz)

# --------------------------------------------------------------
# Optional: LLM Provider Override
# --------------------------------------------------------------
# Override the config.yaml provider selection at runtime
# LLM_PROVIDER=gemini
# LLM_PROVIDER=local

# Google Cloud project (required for Gemini CLI with Workspace accounts)
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# --------------------------------------------------------------
# Optional: FastAPI Server Settings
# --------------------------------------------------------------
PORT=8000
# HOST=0.0.0.0
