# ==============================================================
# SAGE[ai] - Iterative Refinement Route Planning Environment Variables
#
# Copy to .env (or export in your shell) and set values.
# NEVER commit a .env file containing real secrets to git.
# All variables have safe defaults in
#   config/iterative_refinement_route_planning.yaml;
# set here only to override defaults for this environment.
# ==============================================================

# --- LLM Provider ---
# REACT_LLM_PROVIDER=claude-code
#   Valid: gemini | claude-code | ollama | local | generic-cli | claude
# REACT_LLM_MODEL=claude-sonnet-4-6

# --- Iterative Refinement Loop ---
# IR_MAX_ROUNDS=5
#   Maximum generate->critique->refine->check cycles before forced stop.
#   Lower for speed (2-3), higher for quality (8-10).

# IR_QUALITY_THRESHOLD=80
#   Accept the route when the critic scores it at or above this value (0-100).
#   Production regulated environments: consider 90+.

# IR_MIN_IMPROVEMENT=3
#   Stop early if consecutive rounds improve score by less than this delta.
#   Prevents wasted LLM calls when stuck at a local optimum.

# IR_CRITIQUE_MODE=structured
#   How the previous critique is injected into the refiner prompt.
#   structured: key=value fields (recommended)
#   full:       raw critique text

# --- Route Planning Algorithm ---
# ROUTE_ALGORITHM=astar
#   Valid: dijkstra | astar | bfs | dfs | bellman_ford

# --- Graph Source ---
# ROUTE_GRAPH_SOURCE=inline
#   inline: graph provided in task payload JSON
#   file:   loaded from ROUTE_GRAPH_FILE path
# ROUTE_GRAPH_FILE=/data/graphs/city_map.json

# --- Cost Function Weights (must sum to 1.0) ---
# ROUTE_COST_DISTANCE=0.5
# ROUTE_COST_TIME=0.3
# ROUTE_COST_RISK=0.2

# --- Hard Constraints ---
# ROUTE_MAX_HOPS=20
# ROUTE_MAX_DISTANCE_KM=500

# --- Heuristic (A* only) ---
# ROUTE_HEURISTIC=haversine
#   Valid: straight_line | manhattan | haversine

# --- Goal ---
# ROUTE_GOAL=Find the optimal route between start and destination

# --- Output ---
# ROUTE_OUTPUT_NARRATIVE=true
# ROUTE_OUTPUT_HISTORY=false
#   Set to true to include per-round route snapshots in the final output.

# --- Tool Directory ---
# ROUTE_TOOLS_DIR=tools/route_planning

# --- System Prompt Overrides ---
# REACT_AGENT_ROLE=route_planner

# --- HITL Gate ---
# REACT_HITL_ENABLED=false
#   Set to true in regulated or safety-critical deployments.

# --- Secrets (NEVER hard-code; always set via environment) ---
# ANTHROPIC_API_KEY=
# SAGE_SOLUTIONS_DIR=
