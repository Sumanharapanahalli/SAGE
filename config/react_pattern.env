# ==============================================================
# SAGE[ai] - ReAct Pattern Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# All variables have safe defaults in react_pattern.yaml;
# set here only to override defaults for this environment.
# ==============================================================

# --- LLM Provider ---
# REACT_LLM_PROVIDER=claude-code
# REACT_LLM_MODEL=claude-sonnet-4-6

# --- System Prompt ---
# REACT_PROMPT_MODE=file
# REACT_PROMPT_FILE=config/react_system_prompt.yaml
# REACT_AGENT_ROLE=analyst
# REACT_DOMAIN=medical device manufacturing

# --- Tool Registry ---
# REACT_TOOLS_DIR=tools

# --- ReAct Loop ---
# REACT_HITL_ENABLED=true

# --- Secrets (never hard-code — always via env) ---
# ANTHROPIC_API_KEY=
# GITLAB_URL=
# GITLAB_TOKEN=
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=
# N8N_WEBHOOK_SECRET=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
