{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sage:react_route_planning_pipeline_schema",
  "title": "SAGE Multi-Agent Sequential Pipeline Configuration Schema",
  "description": "Validates react_route_planning_pipeline.yaml after env-var substitution. All required fields must be present; no unknown top-level keys allowed.",
  "type": "object",
  "required": ["pipeline", "llm", "tool_registry", "route_planning", "hitl", "stages"],
  "additionalProperties": false,
  "properties": {
    "pipeline": {
      "type": "object",
      "required": ["name", "version", "on_stage_failure", "timeout_seconds", "audit"],
      "additionalProperties": false,
      "properties": {
        "name":    {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "on_stage_failure": {
          "type": "string",
          "enum": ["fail_fast", "continue"]
        },
        "timeout_seconds": {"type": ["integer", "string"]},
        "audit": {
          "type": "object",
          "required": ["enabled", "log_raw_llm_output", "trace_id_header"],
          "additionalProperties": false,
          "properties": {
            "enabled":            {"type": "boolean"},
            "log_raw_llm_output": {"type": "boolean"},
            "trace_id_header":    {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "llm": {
      "type": "object",
      "required": ["provider", "model", "temperature", "max_tokens", "timeout_seconds", "retry"],
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["gemini", "claude-code", "ollama", "local", "generic-cli", "claude"]
        },
        "model":           {"type": "string", "minLength": 1},
        "temperature":     {"type": "number", "minimum": 0.0, "maximum": 1.0},
        "max_tokens":      {"type": "integer", "minimum": 256, "maximum": 32768},
        "timeout_seconds": {"type": "integer", "minimum": 10, "maximum": 600},
        "retry": {
          "type": "object",
          "required": ["max_attempts", "backoff_base_seconds", "retryable_errors"],
          "additionalProperties": false,
          "properties": {
            "max_attempts":         {"type": "integer", "minimum": 1, "maximum": 10},
            "backoff_base_seconds": {"type": "number",  "minimum": 0.5, "maximum": 60},
            "retryable_errors": {
              "type": "array",
              "items": {"type": "string"},
              "minItems": 1
            }
          }
        }
      }
    },
    "tool_registry": {
      "type": "object",
      "required": ["scan_dirs", "disabled", "sandbox", "schema_validation"],
      "additionalProperties": false,
      "properties": {
        "scan_dirs": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1
        },
        "disabled": {
          "type": "array",
          "items": {"type": "string"}
        },
        "sandbox": {
          "type": "object",
          "required": ["enabled", "timeout_seconds", "allow_network"],
          "additionalProperties": false,
          "properties": {
            "enabled":         {"type": "boolean"},
            "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 300},
            "allow_network":   {"type": "boolean"}
          }
        },
        "schema_validation": {
          "type": "object",
          "required": ["enabled", "strict"],
          "additionalProperties": false,
          "properties": {
            "enabled": {"type": "boolean"},
            "strict":  {"type": "boolean"}
          }
        }
      }
    },
    "route_planning": {
      "type": "object",
      "required": ["algorithm", "graph_source", "cost_weights", "constraints", "heuristic", "output"],
      "additionalProperties": false,
      "properties": {
        "algorithm":    {"type": "string", "enum": ["dijkstra", "astar", "bfs", "dfs", "bellman_ford"]},
        "graph_source": {"type": "string", "enum": ["inline", "file"]},
        "graph_file":   {"type": "string"},
        "cost_weights": {
          "type": "object",
          "required": ["distance", "time", "risk"],
          "additionalProperties": false,
          "properties": {
            "distance": {"type": ["number", "string"]},
            "time":     {"type": ["number", "string"]},
            "risk":     {"type": ["number", "string"]}
          }
        },
        "constraints": {
          "type": "object",
          "required": ["max_hops", "max_distance_km", "avoid_node_types", "avoid_edge_labels"],
          "additionalProperties": false,
          "properties": {
            "max_hops":          {"type": ["integer", "string"]},
            "max_distance_km":   {"type": ["number",  "string"]},
            "avoid_node_types":  {"type": "array", "items": {"type": "string"}},
            "avoid_edge_labels": {"type": "array", "items": {"type": "string"}}
          }
        },
        "heuristic": {
          "type": "object",
          "required": ["function", "weight"],
          "additionalProperties": false,
          "properties": {
            "function": {"type": "string", "enum": ["straight_line", "manhattan", "haversine"]},
            "weight":   {"type": "number", "minimum": 0.1, "maximum": 10.0}
          }
        },
        "output": {
          "type": "object",
          "required": ["include_total_cost", "include_intermediate_nodes", "include_cost_breakdown", "narrative"],
          "additionalProperties": false,
          "properties": {
            "include_total_cost":         {"type": "boolean"},
            "include_intermediate_nodes": {"type": "boolean"},
            "include_cost_breakdown":     {"type": "boolean"},
            "narrative": {
              "oneOf": [
                {"type": "boolean"},
                {"type": "string", "enum": ["true", "false"]}
              ]
            }
          }
        }
      }
    },
    "hitl": {
      "type": "object",
      "required": ["enabled", "always_require_approval"],
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "oneOf": [
            {"type": "boolean"},
            {"type": "string", "enum": ["true", "false"]}
          ]
        },
        "always_require_approval": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1
        }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "role", "description", "tools", "react_loop", "system_prompt", "output_fields"],
        "additionalProperties": true,
        "properties": {
          "id":          {"type": "string", "minLength": 1},
          "name":        {"type": "string", "minLength": 1},
          "role":        {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "condition":   {"type": "string"},
          "llm": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "temperature": {"type": "number", "minimum": 0.0, "maximum": 1.0},
              "max_tokens":  {"type": "integer", "minimum": 256, "maximum": 32768}
            }
          },
          "tools": {
            "type": "object",
            "required": ["enabled"],
            "additionalProperties": false,
            "properties": {
              "enabled": {
                "oneOf": [
                  {"type": "string", "const": "*"},
                  {"type": "array", "items": {"type": "string"}, "minItems": 1}
                ]
              }
            }
          },
          "retry_on_failure": {
            "type": "object",
            "required": ["enabled", "max_retries", "retry_stage"],
            "additionalProperties": false,
            "properties": {
              "enabled":     {"type": "boolean"},
              "max_retries": {"type": ["integer", "string"]},
              "retry_stage": {"type": "string", "minLength": 1}
            }
          },
          "react_loop": {
            "type": "object",
            "required": ["max_iterations", "early_stop_on_final_answer", "parsing", "observation"],
            "additionalProperties": false,
            "properties": {
              "max_iterations":             {"type": "integer", "minimum": 1, "maximum": 50},
              "early_stop_on_final_answer": {"type": "boolean"},
              "parsing": {
                "type": "object",
                "required": ["thought_prefix", "action_prefix", "observation_prefix", "final_answer_prefix", "strict"],
                "additionalProperties": false,
                "properties": {
                  "thought_prefix":      {"type": "string", "minLength": 1},
                  "action_prefix":       {"type": "string", "minLength": 1},
                  "observation_prefix":  {"type": "string", "minLength": 1},
                  "final_answer_prefix": {"type": "string", "minLength": 1},
                  "strict":              {"type": "boolean"}
                }
              },
              "observation": {
                "type": "object",
                "required": ["max_chars", "truncation_marker"],
                "additionalProperties": false,
                "properties": {
                  "max_chars":         {"type": "integer", "minimum": 100},
                  "truncation_marker": {"type": "string"}
                }
              }
            }
          },
          "system_prompt": {
            "type": "object",
            "required": ["inline", "variables", "max_chars"],
            "additionalProperties": false,
            "properties": {
              "inline":    {"type": "string", "minLength": 1},
              "variables": {"type": "object", "additionalProperties": {"type": "string"}},
              "max_chars": {"type": "integer", "minimum": 100, "maximum": 128000}
            }
          },
          "input_fields":  {"type": "array", "items": {"type": "string"}},
          "output_fields": {"type": "array", "items": {"type": "string"}, "minItems": 1}
        }
      }
    }
  }
}
