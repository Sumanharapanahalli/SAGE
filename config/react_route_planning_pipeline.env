# ==============================================================
# SAGE[ai] - Multi-Agent Sequential Pipeline Environment Variables
# Domain: Route Planning Algorithm
#
# Copy to .env (or export in your shell) and fill in values.
# NEVER commit a .env file containing real secrets to git.
# All variables have safe defaults in react_route_planning_pipeline.yaml;
# set here only to override defaults for this environment.
# ==============================================================

# --- Pipeline Identity ---
# PIPELINE_NAME=route_planning_pipeline
# PIPELINE_VERSION=1.0.0
# PIPELINE_ON_FAILURE=fail_fast
#   fail_fast: abort on first stage failure (production default)
#   continue:  run all stages, collect all errors (debug only)
# PIPELINE_TIMEOUT_SECONDS=600

# --- LLM Provider (shared across all stages) ---
# REACT_LLM_PROVIDER=claude-code
#   Valid: gemini | claude-code | ollama | local | generic-cli | claude
# REACT_LLM_MODEL=claude-sonnet-4-6

# --- Route Planning Algorithm ---
# ROUTE_ALGORITHM=astar
#   Valid: dijkstra | astar | bfs | dfs | bellman_ford

# --- Graph Source ---
# ROUTE_GRAPH_SOURCE=inline
#   inline: graph provided in task payload JSON
#   file:   graph loaded from ROUTE_GRAPH_FILE path
# ROUTE_GRAPH_FILE=/data/graphs/city_map.json

# --- Start / Destination (injected into solver prompt) ---
# ROUTE_START_NODE=A
# ROUTE_END_NODE=Z

# --- Cost Function Weights (must sum to 1.0) ---
# ROUTE_COST_DISTANCE=0.5
# ROUTE_COST_TIME=0.3
# ROUTE_COST_RISK=0.2

# --- Hard Constraints ---
# ROUTE_MAX_HOPS=20
# ROUTE_MAX_DISTANCE_KM=500

# --- Heuristic (A* only) ---
# ROUTE_HEURISTIC=haversine
#   Valid: straight_line | manhattan | haversine

# --- Goal (injected into planner and narrator prompts) ---
# ROUTE_GOAL=Find the optimal route between start and destination

# --- Output ---
# ROUTE_OUTPUT_NARRATIVE=true

# --- Tool Directory ---
# ROUTE_TOOLS_DIR=tools/route_planning

# --- Stage Roles (override if your solution uses different role names) ---
# PIPELINE_PLANNER_ROLE=route_planner
# PIPELINE_SOLVER_ROLE=route_solver
# PIPELINE_VALIDATOR_ROLE=route_validator
# PIPELINE_NARRATOR_ROLE=route_narrator

# --- Validator Retry Policy ---
# VALIDATOR_MAX_RETRIES=2
#   Maximum times the pipeline loops back to solver on validation failure.

# --- Narrator Condition ---
# NARRATOR_CONDITION=verdict == 'pass'
#   Change to 'always' to run narrator even when validation fails (debug).

# --- HITL Gate ---
# REACT_HITL_ENABLED=false
#   Set to true in regulated or safety-critical deployments.

# --- Secrets (NEVER hard-code; always set via environment) ---
# ANTHROPIC_API_KEY=
# SAGE_SOLUTIONS_DIR=
