# ==============================================================
# SAGE[ai] - ReAct Route Planning Environment Variables
# Copy to .env (or merge into your existing .env) and fill in values.
# NEVER commit a .env file containing real secrets to git.
# All variables have safe defaults in react_route_planning.yaml;
# set here only to override defaults for this environment.
# ==============================================================

# --- LLM Provider ---
# REACT_LLM_PROVIDER=claude-code
# REACT_LLM_MODEL=claude-sonnet-4-6

# --- Route Planning Algorithm ---
# ROUTE_ALGORITHM=astar
#   Valid: dijkstra | astar | bfs | dfs | bellman_ford

# --- Graph Source ---
# ROUTE_GRAPH_SOURCE=inline
#   "inline" = provided in task payload JSON
#   "file"   = loaded from ROUTE_GRAPH_FILE path
# ROUTE_GRAPH_FILE=/data/graphs/city_map.json

# --- Cost Function Weights (must sum to 1.0) ---
# ROUTE_COST_DISTANCE=0.5
# ROUTE_COST_TIME=0.3
# ROUTE_COST_RISK=0.2

# --- Hard Constraints ---
# ROUTE_MAX_HOPS=20
# ROUTE_MAX_DISTANCE_KM=500

# --- Heuristic (A* only) ---
# ROUTE_HEURISTIC=haversine
#   Valid: straight_line | manhattan | haversine

# --- Output ---
# ROUTE_OUTPUT_NARRATIVE=true
# ROUTE_GOAL=Find the optimal route between start and destination

# --- Tool Directory ---
# ROUTE_TOOLS_DIR=tools/route_planning

# --- System Prompt Overrides ---
# REACT_PROMPT_MODE=inline
# REACT_AGENT_ROLE=route_planner
# REACT_DOMAIN=route planning

# --- ReAct Loop ---
# REACT_HITL_ENABLED=false
#   Set to true in regulated or safety-critical deployments.

# --- Secrets (never hard-code) ---
# ANTHROPIC_API_KEY=
# SAGE_SOLUTIONS_DIR=
