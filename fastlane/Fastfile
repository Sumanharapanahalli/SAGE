# frozen_string_literal: true

default_platform(:ios)

platform :ios do
  desc "Run unit tests"
  lane :test do
    run_tests(
      workspace: "MeditationApp.xcworkspace",
      scheme: "MeditationApp",
      destination: "platform=iOS Simulator,name=iPhone 15,OS=latest",
      clean: true,
      output_directory: "./test-results",
      output_files: "junit.xml"
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    # Load App Store Connect API key from environment variables
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true,
      in_house: false
    )

    # Sync code signing certificates via match
    match(
      type: "appstore",
      readonly: true,
      git_url: ENV["MATCH_GIT_URL"],
      app_identifier: ENV["APP_IDENTIFIER"]
    )

    # Increment build number from git commit count
    build_number = sh("git rev-list --count HEAD").strip
    increment_build_number(
      build_number: build_number,
      xcodeproj: "MeditationApp.xcodeproj"
    )

    # Build the app
    gym(
      workspace: "MeditationApp.xcworkspace",
      scheme: "MeditationApp",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      clean: true,
      include_bitcode: false
    )

    # Upload to TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: false,
      notify_external_testers: false,
      changelog: "CI build from commit #{last_git_commit[:abbreviated_commit_hash]}"
    )
  end

  desc "Submit to App Store"
  lane :release do
    # Load App Store Connect API key from environment variables
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true,
      in_house: false
    )

    # Sync code signing certificates via match
    match(
      type: "appstore",
      readonly: true,
      git_url: ENV["MATCH_GIT_URL"],
      app_identifier: ENV["APP_IDENTIFIER"]
    )

    # Increment build number from git commit count
    build_number = sh("git rev-list --count HEAD").strip
    increment_build_number(
      build_number: build_number,
      xcodeproj: "MeditationApp.xcodeproj"
    )

    # Build the app
    gym(
      workspace: "MeditationApp.xcworkspace",
      scheme: "MeditationApp",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      clean: true,
      include_bitcode: false
    )

    # Submit to App Store
    deliver(
      submit_for_review: true,
      automatic_release: false,
      force: true,
      skip_screenshots: true,
      skip_metadata: false,
      reject_if_possible: true
    )
  end
end
